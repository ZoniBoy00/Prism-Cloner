# Prism Cloner — Environment Variables
# Copy this file to .env and fill in the values.

# Discord Bot Token (from https://discord.com/developers)
BOT_TOKEN=your_bot_token_here

# Discord User Token (selfbot — use at your own risk)
DC_TOKEN=your_discord_account_token_here

# Your personal Discord User ID (only this user can run /clone)
ALLOWED_ID=your_personal_user_id
